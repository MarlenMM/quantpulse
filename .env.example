# Copy this file to .env and fill in your own free-tier keys.
# Nothing here is required to run the Phase 0 test suite / migrations.

ENVIRONMENT=development
LOG_LEVEL=INFO

# sqlite = your own persistent local instance (default).
# session = public/shared demo mode, holdings live in-memory per browser session (Section 4.5, 25).
PORTFOLIO_BACKEND=sqlite
DATABASE_URL=sqlite:///./quantpulse.db

# One of: gemini, groq, ollama (Section 4.3, 11). The app runs with this
# entirely unset — the LLM only narrates numbers the analysis engine already computed.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=

# Free API key: https://finnhub.io/register
FINNHUB_API_KEY=

# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Free app registration: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=quantpulse/0.1 by <your-reddit-username>

# SEC requires a descriptive User-Agent identifying you on every EDGAR
# request (no key needed): "<app name> <your contact email>"
SEC_EDGAR_USER_AGENT=quantpulse your-email@example.com

# Where ingestion clients cache raw API responses on disk (gitignored).
INGESTION_CACHE_DIR=.cache

# Point-in-time S&P 500 membership (incl. removed companies) so the cold-start
# backfill is survivorship-bias-aware (Sections 5, 22). Defaults to a public
# interval-format dataset; set HISTORICAL_CONSTITUENTS_PATH to a local CSV to
# pin it, or blank the URL to fall back to today's constituents only.
HISTORICAL_CONSTITUENTS_URL=https://raw.githubusercontent.com/fja05680/sp500/master/sp500_ticker_start_end.csv
# HISTORICAL_CONSTITUENTS_PATH=./data/sp500_ticker_start_end.csv

# How far back the one-time cold-start backfill (scripts/seed_initial_data.py) pulls prices.
SEED_HISTORY_PERIOD=max
